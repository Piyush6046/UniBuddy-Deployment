# Database Configuration
DATABASE_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/UniBuddy?retryWrites=true&w=majority

# Port and Environment Configuration
PORT=4000
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d
NODE_ENV=development

# Email SMTP Configuration (Gmail recommended)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password_here
EMAIL_PASS=your_app_specific_password_here

MAIL_HOST=smtp.gmail.com
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_specific_password_here

# Initial Admin Credentials (for seed/auth setup)
ADMIN_EMAIL=admin@unibuddy.com
ADMIN_PASSWORD=AdminPassword@123

# Frontend URL (CORS allowed list should match this origin in production)
CLIENT_URL=http://localhost:5173

# Cloudinary Configuration (For hosting user uploads/images)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Vapi (Voice AI) Configuration
VAPI_PRIVATE_KEY=your_vapi_private_key_here

# Gemini API Key (Optional / AI models)
GEMINI_API_KEY=your_gemini_api_key_here

# Affinda Resume Parser Configuration (Primary parser)
AFFINDA_API_KEY=your_affinda_api_key_here
AFFINDA_WORKSPACE_ID=your_affinda_workspace_id_here
AFFINDA_DOCUMENT_TYPE_ID=your_affinda_document_type_id_here

# OpenRouter Configuration (Fallback resume parser and model provider)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
